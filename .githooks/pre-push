#!/usr/bin/env bash
# Block direct pushes to main/master.
# Part of the Consilium branch-protection workflow — all changes go through
# a feature branch and PR so the deliberation trail stays intact.
while read local_ref local_sha remote_ref remote_sha; do
    if [[ "$remote_ref" == "refs/heads/main" || "$remote_ref" == "refs/heads/master" ]]; then
        echo "ERROR: direct push to main/master is blocked."
        echo "Use a feature branch:  git checkout -b feat/<slug>"
        echo "Then push the branch and open a PR."
        exit 1
    fi
done
exit 0
